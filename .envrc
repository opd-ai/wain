# wain project environment
#
# This file configures CGO flags required for building and testing the wain
# project. The project uses CGO to link against a static Rust library
# (librender_sys.a) and a musl compatibility stub.
#
# Usage:
#   1. Install direnv: https://direnv.net/
#   2. Run: direnv allow
#   3. Environment will auto-load when entering this directory
#
# Without direnv: source this file manually:
#   source .envrc
#
# This enables running tests directly with:
#   go test ./...
# instead of requiring:
#   make test-go

# Ensure the Rust library and stub are built before setting flags
if [ ! -f "render-sys/target/x86_64-unknown-linux-musl/release/librender_sys.a" ] || \
   [ ! -f "internal/render/dl_find_object_stub.o" ]; then
    echo "⚠️  Required libraries not found. Building dependencies..."
    echo "   Run: make rust"
    # Don't fail - allow direnv to load, but warn the user
fi

# Detect architecture (matches Makefile logic)
RUST_HOST=$(rustc -vV 2>/dev/null | awk '/^host:/{print $2}')
HOST_ARCH=$(echo "$RUST_HOST" | cut -d'-' -f1)
RUST_MUSL_TARGET="${HOST_ARCH}-unknown-linux-musl"

# Paths to Rust library and musl compatibility stub
RUST_LIB="$(pwd)/render-sys/target/${RUST_MUSL_TARGET}/release/librender_sys.a"
DL_STUB="$(pwd)/internal/render/dl_find_object_stub.o"

# Export CGO flags (same as Makefile test-go target)
export CC=musl-gcc
export CGO_ENABLED=1
export CGO_LDFLAGS="${RUST_LIB} ${DL_STUB} -ldl -lm -lpthread"
export CGO_LDFLAGS_ALLOW=".*"

echo "✓ wain CGO environment configured"
echo "  CC=$CC"
echo "  CGO_LDFLAGS=$CGO_LDFLAGS"
